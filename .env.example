# Supabase project settings (from supabase.com/dashboard -> Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API key(s) that external tools (Make.com, Bland.ai/Vapi) must send
# in the "x-api-key" header to reach /api/* routes.
# Generate a strong random string, e.g. `openssl rand -hex 32`
CRM_API_KEY=replace-with-a-long-random-secret

# Make.com webhook URLs (Custom Webhook trigger URLs from your scenarios)
MAKE_OUTBOUND_WEBHOOK_URL=https://hook.make.com/your-outbound-call-scenario
MAKE_NOTIFY_WEBHOOK_URL=https://hook.make.com/your-interested-lead-notify-scenario
# Optional: notified with booking details whenever a booking is created
# (public /book page or POST /api/bookings), e.g. to trigger a Slack alert or reminder.
MAKE_BOOKING_NOTIFY_WEBHOOK_URL=https://hook.make.com/your-booking-notify-scenario

# Google Calendar integration (shared company booking calendar)
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# (Application type: Web application). Add the redirect URI below to
# "Authorized redirect URIs" and enable the Google Calendar API for the project.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://your-deployed-app.vercel.app/api/calendar/oauth/callback

