{
  "name": "sketchers-media-crm-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Desktop shell for the Sketchers Media CRM (wraps the deployed web app)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.sketchersmedia.crm",
    "productName": "Sketchers Media CRM",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "icon.png"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    }
  }
}
